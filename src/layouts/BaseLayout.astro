---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Prabal Banerjee — Co-Founder at Avail, blockchain researcher, former Lead Researcher at Polygon. Research interests in blockchains, interoperability, data availability, and cryptography." } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Prabal Banerjee",
  "url": "https://prabalbanerjee.xyz",
  "jobTitle": "Co-Founder",
  "worksFor": {
    "@type": "Organization",
    "name": "Avail",
    "url": "https://www.availproject.org/"
  },
  "alumniOf": [
    {
      "@type": "CollegeOrUniversity",
      "name": "Indian Statistical Institute, Kolkata",
      "url": "http://www.isical.ac.in/"
    },
    {
      "@type": "CollegeOrUniversity",
      "name": "Chennai Mathematical Institute",
      "url": "http://www.cmi.ac.in/"
    },
    {
      "@type": "CollegeOrUniversity",
      "name": "St. Xavier's College, Kolkata",
      "url": "http://www.sxccal.edu/"
    }
  ],
  "knowsAbout": ["blockchain", "data availability", "interoperability", "cryptography", "fairness", "symmetric key encryption"],
  "sameAs": [
    "https://x.com/prabalbanerjee",
    "https://github.com/prabal-banerjee",
    "https://in.linkedin.com/in/prabal-banerjee",
    "https://scholar.google.com/citations?user=5nHFzjoAAAAJ"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Prabal Banerjee, Avail, Polygon, blockchain, data availability, interoperability, cryptography, ISI Kolkata, researcher" />
    <meta name="author" content="Prabal Banerjee" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Prabal Banerjee" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@prabalbanerjee" />
    <meta name="twitter:creator" content="@prabalbanerjee" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=UA-97017425-1"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "UA-97017425-1");
    </script>
  </head>
  <body>
    <div class="terminal-window">
      <div class="title-bar">
        <div class="traffic-lights">
          <span class="dot red"></span>
          <span class="dot yellow"></span>
          <span class="dot green"></span>
        </div>
        <span class="title-bar-text">prabal@dev:~</span>
      </div>
      <slot />
    </div>
  </body>
</html>
