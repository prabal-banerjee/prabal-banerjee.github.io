---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Publications from '../components/Publications.astro';
import Experience from '../components/Experience.astro';
import Education from '../components/Education.astro';
import Contact from '../components/Contact.astro';
import '../styles/global.css';
---

<BaseLayout title="Prabal Banerjee">
  <div class="terminal-content">
    <Nav />
    <main>
      <Hero />
      <Publications />
      <Experience />
      <Education />
      <Contact />
    </main>
  </div>
</BaseLayout>

<script>
  // Scroll reveal + active nav highlighting
  const scrollRoot = document.querySelector('.terminal-content');
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.tab[data-section]');
  const reveals = document.querySelectorAll('.reveal');

  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    },
    { root: scrollRoot, threshold: 0.1 }
  );

  reveals.forEach((el) => revealObserver.observe(el));

  const setActive = (id) => {
    navLinks.forEach((link) => {
      link.classList.toggle('active', link.dataset.section === id);
    });
  };

  if (scrollRoot && sections.length) {
    const sectionEls = Array.from(sections);
    const lastSection = sectionEls[sectionEls.length - 1];

    const updateActive = () => {
      const atBottom =
        scrollRoot.scrollTop + scrollRoot.clientHeight >=
        scrollRoot.scrollHeight - 2;
      if (atBottom) {
        setActive(lastSection.id);
        return;
      }
      // The active section is the last one whose top has scrolled past
      // ~40% of the scroll container's visible height.
      const threshold = scrollRoot.scrollTop + scrollRoot.clientHeight * 0.4;
      let current = sectionEls[0];
      for (const section of sectionEls) {
        if (section.offsetTop <= threshold) current = section;
        else break;
      }
      setActive(current.id);
    };

    updateActive();
    scrollRoot.addEventListener('scroll', updateActive, { passive: true });
    window.addEventListener('resize', updateActive);
  }
</script>
